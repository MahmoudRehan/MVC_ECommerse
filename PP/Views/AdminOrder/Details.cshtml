@model OrderDetailsVM

<div class="container mt-5 mb-5">

    <!-- Page Header -->
    <div class="row justify-content-center mb-5">

        <div class="col-lg-10 text-center">
            <h1 class="fw-bold">📋 Order Details</h1>
            <p class="text-muted">View your order information and items</p>
        </div>

    </div>

    <div class="row">

        <div class="col-lg-10 m-auto ">

            <!-- Order Information Card -->
            <div class="card shadow-sm border-0 mb-4">

                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Order Information</h5>
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <p class="mb-2">
                                <strong>Order Number:</strong><br />
                                <span class="badge bg-primary fs-6">@Model.OrderNumber</span>
                            </p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <p class="mb-2">
                                <strong>Order Date:</strong><br />
                                <span>@Model.OrderDate.ToString("MMMM dd, yyyy - hh:mm tt")</span>
                            </p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <p class="mb-2">
                                <strong>Status:</strong><br />
                                <span class="badge @Model.StatusBadgeClass fs-6">@Model.StatusText</span>
                                <span>
                                    <a asp-action="UpdateStatus" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                                    Update Status
                                </a>
                                </span>
                            </p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <p class="mb-2">
                                <strong>Total Amount:</strong><br />
                                <span class="text-success fw-bold fs-5">$@Model.TotalAmount</span>
                            </p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <p class="mb-2">
                                <strong>Customer Email:</strong><br />
                                @if (!string.IsNullOrEmpty(Model.CustomerEmail))
                                {
                                    <a href="mailto:@Model.CustomerEmail" class="text-decoration-none">
                                        @Model.CustomerEmail
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Guest / Not available</span>
                                }
                            </p>
                        </div>

                    </div>

                </div>

            </div>

            <!-- Shipping Address Card -->
            <div class="card shadow-sm border-0 mb-4">

                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">🚚 Shipping Address</h5>
                </div>

                <div class="card-body">
                    <address class="mb-0">
                        <strong>@Model.ShippingAddress.Street</strong><br />
                        @Model.ShippingAddress.City, @Model.ShippingAddress.Zip<br />
                        @Model.ShippingAddress.Country
                    </address>
                </div>

            </div>

            <!-- Order Items Card -->
            <div class="card shadow-sm border-0 mb-4">

                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">📦 Order Items</h5>
                </div>

                <div class="card-body">

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Unit Price</th>
                                    <th class="text-center">Quantity</th>
                                    <th class="text-end">Line Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderItems)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="~/Images/Products/@(item.Product?.PictureUrl ?? "no-image.png")"
                                                     class="rounded me-3 shadow-sm"
                                                     alt="@item.Product?.Name"
                                                     style="width: 60px; height: 60px; object-fit: cover;" />
                                                <span class="fw-semibold">@item.Product?.Name</span>
                                            </div>
                                        </td>
                                        <td class="text-center">$@item.UnitPrice</td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary">@item.Quantity</span>
                                        </td>
                                        <td class="text-end fw-bold text-primary">$@item.LineTotal</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold fs-5">Total Amount:</td>
                                    <td class="text-end fw-bold fs-4 text-success">$@Model.TotalAmount</td>
                                </tr>
                            </tfoot>

                        </table>
                       
                    </div>

                </div>

            </div>
           
            <div class="d-grid gap-2">
                <a asp-action="Index" class="btn btn-outline-primary">
                    📋 View All Orders
                </a>
            </div>

        </div>

        

           

                   


    </div>

</div>

<style>
    .sticky-top {
        position: sticky;
    }

    @@media print {
        .btn, .card-header, .sticky-top .card {
            display: none;
        }
    }
</style>
