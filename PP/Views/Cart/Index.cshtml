@model List<CartItem>

<div class="container mt-5 mb-5">

    <!-- Page Header -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold"> Shopping Cart</h1>
        <p class="lead text-muted">Review your items before checkout</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">

            <!-- Cart Items -->
            <div class="col-lg-8">

                <div class="card shadow-sm border-0 mb-4">

                    <div class="card-body">

                        @foreach (var item in Model)
                        {
                            <div class="row cart-item align-items-center mb-4 pb-4 border-bottom">

                                <!-- Product Image -->
                                <div class="col-md-2 col-3">
                                    <img src="~/Images/Products/@(item.PictureUrl ?? "no-image.png")"
                                         class="img-fluid rounded shadow-sm"
                                         alt="@item.ProductName"
                                         style="width: 100%; height: 100px; object-fit: cover;" />
                                </div>

                                <!-- Product Info -->
                                <div class="col-md-4 col-9">
                                    <h5 class="fw-bold mb-2">@item.ProductName</h5>
                                    <p class="text-success fw-bold mb-0">$@item.Price</p>
                                </div>

                                <!-- Quantity Controls -->
                                <div class="col-md-3 col-6 mt-3 mt-md-0">
                                    <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-2">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <label class="form-label mb-0 me-2">Qty:</label>
                                        <input type="number"
                                               name="quantity"
                                               value="@item.Quantity"
                                               min="1"
                                               class="form-control form-control-sm"
                                               style="width: 70px;"
                                               onchange="this.form.submit()" />
                                    </form>
                                </div>

                                <!-- Item Total & Remove -->
                                <div class="col-md-3 col-6 text-end mt-3 mt-md-0">
                                    <p class="fw-bold text-primary mb-2">$@item.TotalPrice</p>
                                    <form asp-action="Remove" method="post" class="d-inline">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                             Remove
                                        </button>
                                    </form>
                                </div>

                            </div>
                        }

                    </div>

                </div>

                <!-- Clear Cart Button -->
                <div class="mb-4">
                    <form asp-action="ClearCart" method="post" onsubmit="return confirm('Are you sure you want to clear your cart?');">
                        <button type="submit" class="btn btn-outline-danger">
                             Clear Cart
                        </button>
                    </form>
                </div>

            </div>

            <!-- Cart Summary -->
            <div class="col-lg-4">

                <div class="card shadow-sm border-0 sticky-top" style="top: 100px;">

                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Cart Summary</h4>
                    </div>

                    <div class="card-body">

                        <!-- Summary Details -->
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Items:</span>
                            <span class="fw-semibold">@ViewBag.ItemCount</span>
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Subtotal:</span>
                            <span class="fw-semibold">$@ViewBag.CartTotal</span>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between mb-4">
                            <span class="fs-5 fw-bold">Total:</span>
                            <span class="fs-4 fw-bold text-success">$@ViewBag.CartTotal</span>
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-controller="Orders" asp-action="Checkout" class="btn btn-success btn-lg">
                                 Proceed to Checkout
                            </a>
                        </div>

                    </div>

                </div>

                <div class="mt-3">
                    <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-primary w-100">
                        ← Continue Shopping
                    </a>
                </div>

            </div>

        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm border-0 text-center py-5">
                    <div class="card-body">
                        <div class="mb-4">
                            <span style="font-size: 80px;">🛒</span>
                        </div>
                        <h3 class="fw-bold mb-3">Your cart is empty</h3>
                        <p class="text-muted mb-4">Start adding products to your cart!</p>
                        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary btn-lg">
                             Start Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@if (TempData["Success"] != null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div class="toast show bg-success text-white" role="alert">
            <div class="toast-body">
                ✅ @TempData["Success"]
            </div>
        </div>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div class="toast show bg-danger text-white" role="alert">
            <div class="toast-body">
                ❌ @TempData["Error"]
            </div>
        </div>
    </div>
}

<style>
    .cart-item {
        transition: background-color 0.2s ease;
    }

        .cart-item:hover {
            background-color: #f8f9fa;
        }

    .sticky-top {
        position: sticky;
    }

    .toast {
        min-width: 250px;
    }
</style>

<script>
    // Auto-hide toast messages after 3 seconds
    setTimeout(function () {
        document.querySelectorAll('.toast').forEach(function (toast) {
            toast.classList.remove('show');
        });
    }, 3000);
</script>
