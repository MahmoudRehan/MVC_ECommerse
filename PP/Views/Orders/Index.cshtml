@model IEnumerable<Order>

<div class="container mt-5 mb-5">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold">Orders</h1>
            <p class="text-muted mb-0">View and manage all orders</p>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <!-- Orders Table -->
        <div class="card shadow-sm border-0">

            <div class="card-body">

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Order Number</th>
                                <th>Order Date</th>
                                <th>Items</th>
                                <th>Total Amount</th>
                                <th>Shipping Address</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-primary">@order.OrderNumber</span>
                                    </td>
                                    <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <span class="badge bg-secondary">@order.OrderItems.Count items</span>
                                    </td>
                                    <td class="fw-bold text-success">$@order.TotalAmount</td>
                                    <td>
                                        <small>@order.ShippingAddress.City, @order.ShippingAddress.Country</small>
                                    </td>
                                    <td>
                                        @{
                                            var statusClass = order.Status switch
                                            {
                                                0 => "bg-warning text-dark",
                                                1 => "bg-info",
                                                2 => "bg-primary",
                                                3 => "bg-success",
                                                4 => "bg-danger",
                                                _ => "bg-secondary"
                                            };

                                            var statusText = order.Status switch
                                            {
                                                0 => "Pending",
                                                1 => "Processing",
                                                2 => "Shipped",
                                                3 => "Delivered",
                                                4 => "Cancelled",
                                                _ => "Unknown"
                                            };
                                        }
                                        <span class="badge @statusClass">@statusText</span>
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details" 
                                           asp-route-id="@order.OrderId" 
                                           class="btn btn-sm btn-info text-white">
                                             View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>

        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm border-0 text-center py-5">
                    <div class="card-body">
                        <div class="mb-4">
                            <span style="font-size: 80px;">📦</span>
                        </div>
                        <h3 class="fw-bold mb-3">No orders yet</h3>
                        <p class="text-muted mb-4">Start shopping to place your first order!</p>
                        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary btn-lg">
                            🛍️ Start Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

</div>
