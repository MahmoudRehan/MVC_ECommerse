@model Product

<div class="container py-5">

    <div class="row g-5">

        <!-- Product Image -->
        <div class="col-lg-6">

            <div class="card shadow-sm border-0 p-4 text-center">

                <img src="~/Images/Products/@(Model.PictureUrl ?? "no-image.png")"
                     class="img-fluid"
                     alt="@Model.Name"
                     style="max-height:450px; object-fit:contain;" />

            </div>

        </div>

        <!-- Product Details -->
        <div class="col-lg-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body p-4">

                    <!-- Category -->
                    <span class="badge bg-primary mb-3 fs-6">
                        @Model.Category?.Name
                    </span>

                    <!-- Product Name -->
                    <h2 class="fw-bold mb-3">@Model.Name</h2>

                    <!-- Rating -->
                    <div class="mb-3">
                        ⭐⭐⭐⭐⭐
                        <span class="text-muted">(120 Reviews)</span>
                    </div>

                    <!-- SKU -->
                    <p class="text-muted mb-2">
                        SKU: <strong>@Model.SKU</strong>
                    </p>

                    <!-- Price -->
                    <h3 class="text-success fw-bold mb-4">
                        $@Model.Price
                    </h3>

                    <!-- Stock -->
                    @if (Model.StockQuantity > 10)
                    {
                        <div class="alert alert-success py-2">
                            ✔ In Stock (@Model.StockQuantity available)
                        </div>
                    }
                    else if (Model.StockQuantity > 0)
                    {
                        <div class="alert alert-warning py-2">
                            ⚠ Only @Model.StockQuantity left
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger py-2">
                            ❌ Out of Stock
                        </div>
                    }

                    <hr />

                    <!-- Add To Cart -->
                    @if (Model.StockQuantity > 0)
                    {
                        <form asp-controller="Cart" asp-action="AddToCart" method="post">

                            <input type="hidden" name="productId" value="@Model.Id" />

                            <button type="submit" class="btn btn-success btn-lg w-100">
                                🛒 Add To Cart
                            </button>

                        </form>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-lg w-100" disabled>
                            Out of Stock
                        </button>
                    }

                    <!-- Continue -->
                    <a asp-action="Index" class="btn btn-outline-dark w-100 mt-3">
                        ← Continue Shopping
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>