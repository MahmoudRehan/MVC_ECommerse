@model ProductVM

<div class="col-12 col-md-6 col-lg-5 m-auto mt-4">

    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-body">

            <h3 class="text-center mb-4">➕ Add New Product</h3>

            <form asp-action="Create" enctype="multipart/form-data" method="post">

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Product Name</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SKU" class="form-label">SKU</label>
                    <input asp-for="SKU" class="form-control" required />
                    <span asp-validation-for="SKU" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Price" class="form-label">Price</label>
                    <input asp-for="Price" class="form-control" required />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="StockQuantity" class="form-label">StockQuantity</label>
                    <input asp-for="StockQuantity" class="form-control" required />
                    <span asp-validation-for="StockQuantity" class="text-danger"></span>
                </div>
                <div class="form-check mb-3">

                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />

                    <label asp-for="IsActive" class="form-check-label">
                        Active Product
                    </label>

                </div>


                <div class="mb-3">
                    <label asp-for="Image" class="form-label">Image </label>
                    <input asp-for="Image" class="form-control" placeholder="Upload Product Image" />
                    <span asp-validation-for="Image" class="text-danger"></span>

                
              

                <div class="mb-3">
                    <label class="form-label">Select Category</label>

                        <select name="CategoryId" class="form-select" required>
                        <option value="">-- Select Category --</option>

                            @foreach (var cat in ViewBag.Categories)
                        {
                            <option value="@cat.Id">
                                @cat.Name
                            </option>
                        }
                    </select>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary w-50 me-2">
                         Back
                    </a>

                    <button type="submit" class="btn btn-success w-50">
                         Save
                    </button>
                </div>

            </form>

            <script src="~/lib/jquery/dist/jquery.js"></script>
            <script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
            <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.js"></script>

        </div>
    </div>

</div>



